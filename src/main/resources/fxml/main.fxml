<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.geometry.Pos?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.forge.controller.MainController" styleClass="root">

    <top>
        <VBox spacing="0">
            <!-- App Header - Branded Top Bar -->
            <HBox styleClass="app-header" alignment="CENTER_LEFT" BorderPane.alignment="CENTER" prefHeight="50">
                <padding>
                    <Insets top="0" bottom="0" left="20" right="20"/>
                </padding>
                
                <!-- Logo/Title -->
                <HBox spacing="10" alignment="CENTER">
                    <Label text="⚔️" styleClass="logo-icon-small"/>
                    <Label text="FORGE" styleClass="app-title"/>
                </HBox>
                
                <Region HBox.hgrow="ALWAYS"/>
                
                <!-- User Stats Mini -->
                <HBox spacing="20" alignment="CENTER">
                    <VBox spacing="0" alignment="CENTER">
                        <Label fx:id="usernameLabel" text="User" styleClass="user-name"/>
                        <Label fx:id="levelLabel" text="Lv.1" styleClass="user-level"/>
                    </VBox>
                    
                    <VBox spacing="2" alignment="CENTER">
                        <HBox spacing="4" alignment="CENTER">
                            <Label text="❤️" styleClass="stat-icon"/>
                            <Label fx:id="hpLabel" text="60/60" styleClass="stat-text"/>
                            <ProgressBar fx:id="hpBar" prefWidth="60" styleClass="mini-bar"/>
                        </HBox>
                        <HBox spacing="4" alignment="CENTER">
                            <Label text="⭐" styleClass="stat-icon"/>
                            <Label fx:id="xpLabel" text="0/100" styleClass="stat-text"/>
                            <ProgressBar fx:id="xpBar" prefWidth="60" styleClass="mini-bar-xp"/>
                        </HBox>
                    </VBox>
                    
                    <HBox spacing="12" alignment="CENTER">
                        <VBox spacing="0" alignment="CENTER">
                            <Label text="🪙" styleClass="stat-icon"/>
                            <Label fx:id="coinsLabel" text="0" styleClass="gold-text"/>
                        </VBox>
                        <VBox spacing="0" alignment="CENTER">
                            <Label text="🏆" styleClass="stat-icon"/>
                            <Label fx:id="rankLabel" text="100" styleClass="rank-text"/>
                        </VBox>
                    </HBox>
                </HBox>
                
                <Region HBox.hgrow="ALWAYS"/>
                
                <!-- Quick Actions -->
                <HBox spacing="8" alignment="CENTER">
                    <Button text="⚔️ Battle" styleClass="nav-btn-battle" onAction="#openBattle"/>
                    <Button text="🎒 Inventory" styleClass="nav-btn" onAction="#openInventory"/>
                    <Button text="📜 Quests" styleClass="nav-btn" onAction="#openAllActiveQuests"/>
                    <Button text="🏅 Leaderboard" styleClass="nav-btn" onAction="#openLeaderboard"/>
                    <Button text="🎖️ Achievements" styleClass="nav-btn" onAction="#openAchievements"/>
                    <Button text="❌" styleClass="close-btn" onAction="#logout"/>
                </HBox>
            </HBox>
            
            <!-- Mode Switcher Bar -->
            <HBox styleClass="mode-bar" alignment="CENTER_LEFT" spacing="10">
                <padding>
                    <Insets top="8" bottom="8" left="20" right="20"/>
                </padding>
                <Label text="Active Modes:" styleClass="mode-label"/>
                <HBox fx:id="activeModesContainer" spacing="8"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="+ New Mode" styleClass="create-mode-btn" onAction="#createCustomMode"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox alignment="TOP_CENTER" spacing="20" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="30" left="40" right="40"/>
            </padding>
            
            <HBox alignment="CENTER" spacing="20">
                <Label text="CHOOSE YOUR ADVENTURE" styleClass="section-title"/>
            </HBox>
            
            <ScrollPane hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" styleClass="mode-scroll" fitToWidth="true" prefHeight="400">
                <VBox fx:id="modeContainer" spacing="16" alignment="TOP_CENTER">
                    <padding>
                        <Insets top="10" bottom="10" left="20" right="20"/>
                    </padding>
                </VBox>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>