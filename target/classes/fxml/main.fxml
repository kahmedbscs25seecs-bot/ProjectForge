<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.forge.controller.MainController" styleClass="root">

    <top>
        <VBox spacing="0">
            <!-- Header Bar with pill buttons -->
            <HBox styleClass="stats-panel" alignment="CENTER_LEFT" BorderPane.alignment="CENTER">
                <padding>
                    <Insets top="8" bottom="8" left="16" right="16"/>
                </padding>
                
                <!-- Left: Username & Level -->
                <VBox spacing="2" alignment="CENTER_LEFT">
                    <Label fx:id="usernameLabel" text="Username" styleClass="title-label"/>
                    <Label fx:id="levelLabel" text="Level 1" styleClass="text-label"/>
                </VBox>
                
                <Region HBox.hgrow="ALWAYS"/>
                
                <!-- Center: HP & XP Bars Side by Side -->
                <HBox spacing="20" alignment="CENTER">
                    <HBox spacing="8" alignment="CENTER">
                        <Label text="HP" styleClass="small-label"/>
                        <Label fx:id="hpLabel" text="60/60" styleClass="green-text"/>
                    </HBox>
                    <ProgressBar fx:id="hpBar" prefWidth="80" styleClass="hp-bar"/>
                    
                    <HBox spacing="8" alignment="CENTER">
                        <Label text="XP" styleClass="small-label"/>
                        <Label fx:id="xpLabel" text="0/100" styleClass="cyan-text"/>
                    </HBox>
                    <ProgressBar fx:id="xpBar" prefWidth="80" styleClass="xp-bar"/>
                </HBox>
                
                <Region HBox.hgrow="ALWAYS"/>
                
                <!-- Right Stats: Coins & Rank -->
                <HBox spacing="15" alignment="CENTER">
                    <VBox spacing="0" alignment="CENTER">
                        <Label text="Coins" styleClass="small-label"/>
                        <Label fx:id="coinsLabel" text="0" styleClass="gold-text"/>
                    </VBox>
                    <VBox spacing="0" alignment="CENTER">
                        <Label text="Rank" styleClass="small-label"/>
                        <Label fx:id="rankLabel" text="100" styleClass="purple-text"/>
                    </VBox>
                </HBox>
                
                <Region HBox.hgrow="ALWAYS"/>
                
                <!-- Right: Pill Buttons -->
                <VBox spacing="6" alignment="CENTER_RIGHT">
                    <!-- Top Row: Battle (large), Inv, Quests -->
                    <HBox spacing="6" alignment="CENTER">
                        <Button text="Battle" styleClass="pill-battle" onAction="#openBattle"/>
                        <Button text="Inv" styleClass="pill-button" onAction="#openInventory"/>
                        <Button text="Quests" styleClass="pill-button" onAction="#openAllActiveQuests"/>
                    </HBox>
                    <!-- Bottom Row: Leaderboard, Badges, X -->
                    <HBox spacing="6" alignment="CENTER">
                        <Button text="Leaderboard" styleClass="pill-button" onAction="#openLeaderboard"/>
                        <Button text="Badges" styleClass="pill-button" onAction="#openAchievements"/>
                        <Button text="X" styleClass="close-button" onAction="#logout"/>
                    </HBox>
                </VBox>
            </HBox>
            
            <!-- Mode Switcher -->
            <HBox styleClass="mode-switcher" alignment="CENTER_LEFT" spacing="12">
                <padding>
                    <Insets top="6" bottom="6" left="16" right="16"/>
                </padding>
                <Label text="Active:" styleClass="text-label"/>
                <HBox fx:id="activeModesContainer" spacing="8"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox alignment="TOP_CENTER" spacing="20" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="20" left="40" right="40"/>
            </padding>
            
            <Label text="SELECT YOUR MODE" styleClass="title-label"/>
            
            <ScrollPane hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" styleClass="scroll-pane" fitToWidth="true" prefHeight="350">
                <VBox fx:id="modeContainer" spacing="18" alignment="TOP_CENTER">
                    <padding>
                        <Insets top="10" bottom="10"/>
                    </padding>
                </VBox>
            </ScrollPane>
            
            <Button text="+ Create Custom Mode" styleClass="pill-button" onAction="#createCustomMode"/>
        </VBox>
    </center>
</BorderPane>