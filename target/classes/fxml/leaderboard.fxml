<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.forge.controller.LeaderboardController" styleClass="root">

    <top>
        <HBox styleClass="stats-panel" alignment="CENTER_LEFT" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="8" bottom="8" left="20" right="20"/>
            </padding>
            
            <Label fx:id="userRankLabel" text="Your Rank: #--" styleClass="title-label"/>
            
            <Region HBox.hgrow="ALWAYS"/>
            
            <Button text="Back" styleClass="secondary-button" onAction="#goBack"/>
        </HBox>
    </top>

    <center>
        <VBox alignment="TOP_CENTER" spacing="15" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="20" left="30" right="30"/>
            </padding>
            
            <Label text="TOP PLAYERS" styleClass="title-label"/>
            
            <ScrollPane styleClass="scroll-pane" fitToWidth="true" prefHeight="200">
                <VBox fx:id="leaderboardContainer" spacing="8"/>
            </ScrollPane>
            
            <Label text="YOUR BATTLES" styleClass="title-label"/>
            <ScrollPane styleClass="scroll-pane" fitToWidth="true" prefHeight="150">
                <VBox fx:id="battleHistoryContainer" spacing="8"/>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>